# ============================================================
# Bloqueia acesso direto a planilhas de participantes
# (contém dados pessoais: CPF, e-mail, matrícula, cargo, secretaria).
# Estes arquivos são insumo do extrator Python — não devem ser
# servidos diretamente pelo webserver.
# ============================================================

# Apache 2.4+
<FilesMatch "(?i)\.(xlsx|xls|csv|ods|tsv)$">
    Require all denied
</FilesMatch>

# Apache 2.2 (compatibilidade)
<IfModule !mod_authz_core.c>
    <FilesMatch "(?i)\.(xlsx|xls|csv|ods|tsv)$">
        Order allow,deny
        Deny from all
    </FilesMatch>
</IfModule>

# Bloqueia também o script Python e o manual.json (configuração interna)
<FilesMatch "(?i)\.(py|json)$">
    Require all denied
</FilesMatch>

# Listagem de diretório desabilitada
Options -Indexes
