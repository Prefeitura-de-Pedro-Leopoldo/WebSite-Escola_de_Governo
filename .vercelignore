# Arquivos e pastas excluídos do deploy na Vercel.
# O conteúdo continua versionado no repositório, apenas não é publicado.

# Painel administrativo — não vai para produção
admin/

# Documentação interna e propostas
docs/

# OBS: scripts/ NÃO deve ser ignorado — o build (`npm run build`) executa
# scripts/gerar-galerias.mjs antes do deploy. Sem ele o build quebra.

# Configurações locais e de desenvolvimento
.git/
.gitignore
.vscode/
.idea/
node_modules/

# Arquivos temporários
*.log
.DS_Store
Thumbs.db
